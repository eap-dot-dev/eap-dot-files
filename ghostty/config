# ---------- Theme ----------
# Default to a dark theme (swap to your favorite built-in or custom).
# If you ever want auto light/dark, use: theme = dark:<DarkName>,light:<LightName>
# theme = "JetBrains Darcula"

# ---------- Fonts (optional defaults) ----------
font-family = "JetBrains Mono"
font-size = 16

# ---------- Window feel (optional niceties) ----------
macos-titlebar-style = transparent
window-padding-x = 8
window-padding-y = 8

# ---------- Quick Window / Quick Terminal ----------
# Global hotkey to toggle from anywhere:
# Use macOS “Cmd + `” (backquote/backtick) globally.
keybind = global:cmd+backquote=toggle_quick_terminal

# Place the quick window in the center of the active display:
quick-terminal-position = center

# Make it 75% of screen height AND width (percent syntax supported since 1.2):
quick-terminal-size = 90%,90%

# Keep it around when you switch Spaces (optional—pick your preference):
# quick-terminal-space-behavior = move   # (default) follow you
# quick-terminal-space-behavior = remain # stay on the original Space

# Auto-hide when focus leaves (optional):
quick-terminal-autohide = true

quick-terminal-animation-duration = 0
